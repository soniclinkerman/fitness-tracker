# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Ignore bundler config.
/.bundle

# Ignore all environment files.
/.env*

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

# Ignore master key for decrypting credentials and more.
/config/master.key

# Ignore node modules
/node_modules
fitness-frontend/node_modules

# Ignore bundled gems
/vendor/bundle
/gems
/cache
/extensions
/specifications
/plugins

# Ignore generated binstubs (keep only the essential ones)
/bin/bootsnap
/bin/dotenv
/bin/erb
/bin/htmldiff
/bin/irb
/bin/ldiff
/bin/nokogiri
/bin/puma
/bin/pumactl
/bin/racc
/bin/rackup
/bin/rdbg
/bin/rdoc
/bin/ri
/bin/rspec
/bin/ruby-parse
/bin/ruby-rewrite
/bin/thor

# Ignore IDE files
.idea/

# Ignore Cypress artifacts
cypress/screenshots
cypress/videos

# Ignore Claude settings
.claude/
